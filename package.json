{
  "name": "vastra",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": "8.15.0"
  },
  "scripts": {
    "api:check": "corepack pnpm api:generate && git diff --exit-code -- packages/api-client/src/generated/schema.ts",
    "api:generate": "corepack pnpm --filter @vastra/api-client generate",
    "build": "turbo run build",
    "db:test": "bash scripts/run-db-tests.sh",
    "lint": "eslint . --max-warnings=0",
    "openapi:check": "redocly lint docs/api/openapi.yaml --extends=spec",
    "security:audit": "corepack pnpm audit --prod --audit-level high",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "typecheck": "turbo run typecheck",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "env:check": "tsx scripts/validate-env.mts"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@redocly/cli": "2",
    "@types/node": "24",
    "@vitest/eslint-plugin": "1.6.23",
    "eslint": "9.39.5",
    "eslint-plugin-n": "18.2.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "tsx": "4",
    "turbo": "2.10.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "3.2.7"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.19",
      "xcode>uuid": "11.1.1"
    }
  }
}
