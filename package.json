{
  "name": "vastra",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": "20.20.2",
    "pnpm": "8.15.0"
  },
  "scripts": {
    "build": "turbo run build",
    "db:test": "bash scripts/run-db-tests.sh",
    "env:check": "tsx scripts/validate-env.mts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm --filter @vastra/api-client generate && eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "openapi:check": "redocly lint docs/api/openapi.yaml --extends=spec",
    "pilot:evidence:check": "node scripts/validate-pilot-evidence.mjs",
    "pilot:go-no-go": "node scripts/validate-pilot-evidence.mjs --enforce-go",
    "security:client-secrets": "node scripts/scan-client-secrets.mjs",
    "test": "turbo run test",
    "test:frontend:e2e": "playwright test --project=admin --project=mobile",
    "test:frontend:fixtures": "pnpm --filter @vastra/frontend-test-harness test",
    "test:frontend:harness": "pnpm test:frontend:fixtures && playwright test",
    "test:frontend:visual": "playwright test --project=visual",
    "test:frontend:visual:update": "pnpm --filter @vastra/frontend-test-harness visual:update",
    "test:integration": "turbo run test:integration",
    "test:pilot-tooling": "node scripts/run-pilot-tooling-tests.mjs",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.55.1",
    "@redocly/cli": "2",
    "@types/node": "20",
    "@vitest/eslint-plugin": "1.6.23",
    "eslint": "9.39.5",
    "eslint-plugin-n": "18.2.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "tsx": "4",
    "turbo": "2.10.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "3.2.7"
  }
}
