    },
    "react-native-safe-area-context": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "5.7.0",
    "vitest": "3.2.7"
  }
