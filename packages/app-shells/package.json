{
  "name": "@vastra/app-shells",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./native": {
      "types": "./src/native.tsx",
      "import": "./src/native.tsx",
      "default": "./src/native.tsx"
    },
    "./admin": {
      "types": "./src/admin.tsx",
      "import": "./src/admin.tsx",
      "default": "./src/admin.tsx"
    }
  },
  "scripts": {
