{
  "name": "@vastra/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "generate": "node scripts/generate-openapi-types.mjs",
    "prelint": "pnpm generate",
    "lint": "eslint . --max-warnings=0",
    "pretypecheck": "pnpm generate",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm generate",
    "test": "vitest run",
    "pretest:coverage": "pnpm generate",
    "test:coverage": "pnpm --dir ../server-state exec vitest run --root ../api-client --coverage --coverage.provider=custom --coverage.customProviderModule=../server-state/node_modules/@vitest/coverage-v8/dist/index.js --coverage.include=src/client.ts --coverage.include=src/errors.ts --coverage.include=src/index.ts --coverage.include=src/logging.ts --coverage.include=src/schema.ts --coverage.thresholds.lines=80 --coverage.thresholds.functions=80 --coverage.thresholds.branches=80 --coverage.thresholds.statements=80",
    "prebuild": "pnpm generate",
    "build": "tsc --noEmit"
  }
}
