{
  "name": "@vastra/api-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "generate": "node scripts/generate-openapi-types.mjs",
    "prelint": "pnpm generate",
    "lint": "eslint . --max-warnings=0",
    "pretypecheck": "pnpm generate",
    "typecheck": "tsc --noEmit",
    "pretest": "pnpm generate",
    "test": "vitest run",
    "pretest:coverage": "pnpm generate",
    "test:coverage": "node scripts/run-coverage.mjs",
    "prebuild": "pnpm generate",
    "build": "tsc --noEmit"
  }
}
