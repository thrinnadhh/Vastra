{
  "name": "@vastra/backend",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "build": "nest build"
  },
  "dependencies": {
    "@nestjs/common": "11",
    "@nestjs/core": "11",
    "@nestjs/platform-express": "11",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11",
    "@types/node": "20.19.43",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  }
}
