APP_ENV=development
NODE_ENV=development
LOG_LEVEL=info
PORT=8080

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=replace-with-local-publishable-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

PAYMENT_PROVIDER=cashfree
PAYMENT_SECRET_KEY=replace-with-local-payment-secret
PAYMENT_WEBHOOK_SECRET=replace-with-local-webhook-secret

SMS_PROVIDER=msg91
SMS_API_KEY=replace-with-local-sms-secret

MERCHANT_ALERT_DELIVERY_ENABLED=false
MERCHANT_ALERT_DELIVERY_WORKER_ID=local-backend
MERCHANT_ALERT_DELIVERY_POLL_INTERVAL_MS=5000
MERCHANT_ALERT_DELIVERY_BATCH_SIZE=10
MERCHANT_ALERT_DELIVERY_REQUEST_TIMEOUT_MS=10000
FCM_PROJECT_ID=local-project-placeholder
FCM_CLIENT_EMAIL=firebase-admin@example.invalid
FCM_PRIVATE_KEY=replace-with-local-private-key

MAPS_API_KEY=replace-with-local-maps-secret
