+import { describe, expect, it } from 'vitest';
+
+import { DeliveryGatewayUnavailableError, parseCaptainDeliverySnapshot } from './delivery.gateway';
+
+const TASK_ID = '10000000-0000-4000-8000-000000000001';
+const ORDER_ID = '20000000-0000-4000-8000-000000000001';
+const ASSIGNMENT_ID = '30000000-0000-4000-8000-000000000001';
+
+const valid = {
+  taskId: TASK_ID,
+  orderId: ORDER_ID,
+  taskType: 'FORWARD_DELIVERY',
+  taskStatus: 'OFFERED',
+  assignmentId: ASSIGNMENT_ID,
+  assignmentStatus: 'OFFERED',
+  offeredEarningPaise: 4500,
+  offerExpiresAt: '2026-07-17T12:00:30.000Z',
+  pickupDistanceMeters: 850,
+  pickup: {
+    shopId: '40000000-0000-4000-8000-000000000001',
+    shopName: 'Vastra Test Shop',
+    label: 'Store',
+    line1: '1 Main Road',
+    line2: null,
+    landmark: null,
+    area: 'Tirupati',
+    city: 'Tirupati',
+    state: 'Andhra Pradesh',
+    postalCode: '517501',
+    countryCode: 'IN',
+    latitude: 13.6288,
+    longitude: 79.4192,
+  },
+  dropArea: { area: 'Renigunta Road', city: 'Tirupati' },
+  assignedAt: null,
+  arrivedPickupAt: null,
+  scheduledAt: '2026-07-17T12:00:00.000Z',
+  updatedAt: '2026-07-17T12:00:00.000Z',
+};
+
+describe('delivery gateway parser', () => {
+  it('maps a safe captain delivery payload', () => {
+    expect(parseCaptainDeliverySnapshot(valid)).toMatchObject({
+      taskId: TASK_ID,
+      assignmentId: ASSIGNMENT_ID,
+      taskStatus: 'OFFERED',
+      pickup: { shopName: 'Vastra Test Shop' },
+    });
+  });
+
+  it('rejects secrets and invalid task states through strict payload parsing', () => {
+    expect(() => parseCaptainDeliverySnapshot({ ...valid, taskStatus: 'COMPLETED' })).toThrow(
+      DeliveryGatewayUnavailableError,
+    );
+    expect(() => parseCaptainDeliverySnapshot({ ...valid, assignmentId: 'bad' })).toThrow(
+      DeliveryGatewayUnavailableError,
+    );
+  });
+});
