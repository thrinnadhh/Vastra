+import { HttpException, HttpStatus } from '@nestjs/common';
+
+function create(
+  status: HttpStatus,
+  code: string,
+  message: string,
+  retryable: boolean,
+): HttpException {
+  return new HttpException(
+    {
+      success: false,
+      error: { code, message, details: null, retryable },
+      requestId: null,
+    },
+    status,
+  );
+}
+
+export function createDeliveryRequestInvalidException(): HttpException {
+  return create(
+    HttpStatus.BAD_REQUEST,
+    'DELIVERY_REQUEST_INVALID',
+    'The delivery request is invalid.',
+    false,
+  );
+}
+
+export function createDeliveryIdempotencyRequiredException(): HttpException {
+  return create(
+    HttpStatus.BAD_REQUEST,
+    'IDEMPOTENCY_KEY_REQUIRED',
+    'A valid Idempotency-Key is required.',
+    false,
+  );
+}
+
+export function createDeliveryAccessDeniedException(): HttpException {
+  return create(
+    HttpStatus.FORBIDDEN,
+    'DELIVERY_ACCESS_DENIED',
+    'Delivery access is denied.',
+    false,
+  );
+}
+
+export function createCaptainNotEligibleException(): HttpException {
+  return create(
+    HttpStatus.FORBIDDEN,
+    'CAPTAIN_NOT_ELIGIBLE',
+    'The captain is not operationally eligible.',
+    false,
+  );
+}
+
+export function createDeliveryTaskNotFoundException(): HttpException {
+  return create(
+    HttpStatus.NOT_FOUND,
+    'DELIVERY_TASK_NOT_FOUND',
+    'The delivery task was not found.',
+    false,
+  );
+}
+
+export function createDeliveryOfferNotFoundException(): HttpException {
+  return create(
+    HttpStatus.NOT_FOUND,
+    'DELIVERY_OFFER_NOT_FOUND',
+    'The delivery offer was not found.',
+    false,
+  );
+}
+
+export function createDeliveryStateConflictException(): HttpException {
+  return create(
+    HttpStatus.CONFLICT,
+    'DELIVERY_STATE_CONFLICT',
+    'The current delivery state rejects this action.',
+    false,
+  );
+}
+
+export function createDeliveryAlreadyAssignedException(): HttpException {
+  return create(
+    HttpStatus.CONFLICT,
+    'DELIVERY_TASK_ALREADY_ASSIGNED',
+    'Another captain already owns the delivery.',
+    false,
+  );
+}
+
+export function createCaptainAlreadyAssignedException(): HttpException {
+  return create(
+    HttpStatus.CONFLICT,
+    'CAPTAIN_ALREADY_ASSIGNED',
+    'The captain already owns another active delivery.',
+    false,
+  );
+}
+
+export function createDeliveryIdempotencyConflictException(): HttpException {
+  return create(
+    HttpStatus.CONFLICT,
+    'IDEMPOTENCY_KEY_REUSED',
+    'The idempotency key was reused with another request.',
+    false,
+  );
+}
+
+export function createDeliveryOfferExpiredException(): HttpException {
+  return create(
+    HttpStatus.GONE,
+    'DELIVERY_OFFER_EXPIRED',
+    'The delivery offer has expired.',
+    false,
+  );
+}
+
+export function createCaptainNotAtPickupException(): HttpException {
+  return create(
+    HttpStatus.CONFLICT,
+    'CAPTAIN_NOT_AT_PICKUP',
+    'The captain is not close enough to the pickup location.',
+    false,
+  );
+}
+
+export function createDeliveryUnavailableException(): HttpException {
+  return create(
+    HttpStatus.SERVICE_UNAVAILABLE,
+    'DELIVERY_SERVICE_UNAVAILABLE',
+    'Delivery services are temporarily unavailable.',
+    true,
+  );
+}
